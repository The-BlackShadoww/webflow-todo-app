{
  "name": "todo-cdn",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "release": "node scripts/upload.mjs dev",
    "release:staging": "dotenv -e .env.staging -- node scripts/upload.mjs staging",
    "release:production": "dotenv -e .env.production -- node scripts/upload.mjs production",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@types/node": "^22.10.1",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "terser": "^5.36.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
