{
  "name": "flowappz-todo-app",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:backend": "pnpm --filter todo-backend dev",
    "dev:frontend": "pnpm --filter todo-frontend dev",
    "dev:cdn": "pnpm --filter todo-cdn dev",
    "build:backend": "pnpm --filter todo-backend build",
    "build:frontend": "pnpm --filter todo-frontend build",
    "build:cdn": "pnpm --filter todo-cdn build",
    "start:backend": "pnpm --filter todo-backend start",
    "db:push": "pnpm --filter todo-backend db:push"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
